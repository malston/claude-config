{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(python3:*)",
      "Bash(python:*)",
      "Bash(rm:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "Bash(sed:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(make test:*)",
      "mcp__git__git_commit",
      "Bash(curl:*)",
      "Bash(source:*)",
      "Bash(time make:*)",
      "Bash(gh issue list:*)",
      "Bash(npm test:*)",
      "Bash(git commit:*)",
      "Skill(code-reviewer)",
      "Bash(npm run test:coverage:*)",
      "Bash(npm run coverage:*)",
      "Bash(git add:*)",
      "Bash(HEADLESS=true npm run test:e2e:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "acceptEdits"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/log-bash-commands.sh"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/block-dangerous-commands.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protect-sensitive-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/format-on-save.sh"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "notify-send 'Claude Code' 'Awaiting your input'"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "cship"
  },
  "enabledPlugins": {
    "claude-hud@claude-hud": false,
    "claude-mem@thedotmack": true,
    "code-refactoring@claude-code-workflows": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "codebase-cleanup@claude-code-workflows": true,
    "commit-commands@claude-plugins-official": true,
    "comprehensive-review@claude-code-workflows": true,
    "dependency-management@claude-code-workflows": true,
    "developer-essentials@claude-code-workflows": true,
    "elements-of-style@superpowers-marketplace": true,
    "episodic-memory@superpowers-marketplace": true,
    "feature-dev@claude-plugins-official": true,
    "framework-migration@claude-code-workflows": true,
    "frontend-design@claude-plugins-official": true,
    "full-stack-orchestration@claude-code-workflows": true,
    "git-pr-workflows@claude-code-workflows": true,
    "github@claude-plugins-official": true,
    "gopls-lsp@claude-plugins-official": true,
    "paivot-graph@paivot-graph": true,
    "playground@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "safety-hooks@cctools-plugins": false,
    "security-compliance@claude-code-workflows": true,
    "security-guidance@claude-plugins-official": true,
    "security-scanning@claude-code-workflows": true,
    "senior-frontend@awesome-claude-plugins": false,
    "shell-scripting@claude-code-workflows": true,
    "swift-lsp@claude-plugins-official": false,
    "superpowers-developing-for-claude-code@superpowers-marketplace": true,
    "superpowers-lab@superpowers-marketplace": true,
    "superpowers@superpowers-marketplace": true,
    "team-collaboration@claude-code-workflows": true,
    "vercel@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "cctools-plugins": {
      "source": {
        "source": "github",
        "repo": "pchalasani/claude-code-tools"
      }
    },
    "claude-code-workflows": {
      "source": {
        "source": "github",
        "repo": "wshobson/agents"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    },
    "superpowers-marketplace": {
      "source": {
        "source": "github",
        "repo": "obra/superpowers-marketplace"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "paivot-graph": {
      "source": {
        "source": "directory",
        "path": "/Users/markalston/code/paivot-graph"
      }
    }
  },
  "sandbox": {
    "allowUnsandboxedCommands": true
  },
  "skipDangerousModePermissionPrompt": true
}
